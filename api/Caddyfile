{
    # Railway 内部、HTTPS 終端は不要
    auto_https off
    admin off
    persist_config off
}

# Railway は PORT 環境変数を渡してくる
:{$PORT:80} {
    root * /app/public
    encode gzip

    # ===== CORS =====
    # Origin が許可リストに合致するときだけ Allow-Origin を反射
    @allowed_origin header_regexp Origin "^https://(kaden-shift\.hito-kiwa\.co\.jp|shift-system-production-d9e8\.up\.railway\.app|[a-z0-9-]+\.up\.railway\.app)$"
    header @allowed_origin Access-Control-Allow-Origin "{http.request.header.Origin}"
    header @allowed_origin Vary "Origin"

    header {
        Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
        Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With"
        Access-Control-Max-Age "3600"
        Access-Control-Allow-Credentials "true"
        Access-Control-Expose-Headers "Content-Length, Content-Type"
        Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Pragma "no-cache"
        Expires "0"
    }

    # ===== OPTIONS プリフライトは即 204 で返す =====
    @options method OPTIONS
    handle @options {
        respond 204
    }

    # ===== ログ・バックアップ系へのアクセス禁止 =====
    @blocked path_regexp \.(log|txt|bak|backup)$
    handle @blocked {
        respond 403
    }

    # ===== クリーン URL を実 PHP に書き換え =====
    # /tables/users → tables/users.php?path=
    # /tables/users/abc → tables/users.php?path=abc
    # 実ファイルが存在する場合 (例: /tables/users.php) はそのまま処理
    @clean_url {
        not file
        path_regexp tables ^/tables/([^/]+)/?(.*)$
    }
    rewrite @clean_url /tables/{re.tables.1}.php?path={re.tables.2}

    # PHP 実行
    php_server
}
